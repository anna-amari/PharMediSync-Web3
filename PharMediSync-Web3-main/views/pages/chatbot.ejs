<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>

<div class="main-area">
  <%- include('../partials/header') %>

  <div class="content">

    <div class="page-header">
      <div>
        <h1>Chatbot Handling</h1>
        <p>Manage client messages and respond quickly with auto-replies.</p>
      </div>
    </div>

    <!-- Chat Logs Table -->
    <div class="table-card">
      <div class="table-header">
        <h2>Chat Logs</h2>
        <div class="flex gap-3">
          <input type="text" placeholder="Search chats…" style="padding:7px 12px;border:1.5px solid var(--gray-200);border-radius:8px;font-size:0.8rem" id="searchBox" oninput="filterTable('chatTable', this.value)" />
        </div>
      </div>
      <table id="chatTable">
        <thead>
          <tr>
            <th>ID</th><th>Client</th><th>Message</th><th>Reply</th><th>Time</th><th>Status</th><th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% chatLogs.forEach(chat => { %>
            <tr>
              <td><span style="font-size:0.72rem;color:var(--gray-400)"><%= chat.id %></span></td>
              <td><strong><%= chat.client %></strong></td>
              <td><%= chat.message %></td>
              <td><%= chat.reply ? chat.reply : '-' %></td>
              <td><%= chat.time %></td>
              <td>
                <% if(chat.status==='Resolved') { %>
                  <span class="badge badge-success">Resolved</span>
                <% } else if(chat.status==='Escalated') { %>
                  <span class="badge badge-warning">Escalated</span>
                <% } else { %>
                  <span class="badge badge-info">Pending</span>
                <% } %>
              </td>
              <td>
                <% if(!chat.reply) { %>
                  <form action="/chatbot/reply" method="POST" style="display:flex;gap:6px">
                    <input type="hidden" name="id" value="<%= chat.id %>">
                    <input type="text" name="reply" placeholder="Type reply…" required style="flex:1"/>
                    <button type="submit" class="btn btn-sm btn-primary">Send</button>
                  </form>
                <% } else { %>
                  Replied
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Auto Replies -->
    <div class="table-card mt-6">
      <div class="table-header">
        <h2>Auto Replies</h2>
      </div>
      <ul>
        <% for(let key in autoReplies) { %>
          <li><strong><%= key %>:</strong> <%= autoReplies[key] %></li>
        <% } %>
      </ul>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>

<script>
  // Simple search filter for tables
  function filterTable(tableId, query) {
    const table = document.getElementById(tableId);
    const tr = table.getElementsByTagName('tr');
    query = query.toLowerCase();
    for(let i=1;i<tr.length;i++){
      const tds = tr[i].getElementsByTagName('td');
      let match = false;
      for(let j=0;j<tds.length-1;j++){
        if(tds[j].innerText.toLowerCase().includes(query)){ match=true; break; }
      }
      tr[i].style.display = match ? '' : 'none';
    }
  }
</script>