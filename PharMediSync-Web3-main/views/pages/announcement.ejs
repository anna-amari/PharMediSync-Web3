<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>

<div class="main-area">
  <%- include('../partials/header') %>

  <div class="content">
    <!-- Page Header -->
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
      <div>
        <h1>Announcements</h1>
        <p>Post system-wide notices for all user groups.</p>
      </div>
      <a href="#postAnnouncement" class="btn btn-primary">＋ Post Announcement</a>
    </div>

    <!-- Announcements List -->
    <div class="announcements-list" style="display:flex; flex-direction:column; gap:16px;">
      <% if (announcements && announcements.length > 0) { %>
        <% announcements.forEach(function(a) { %>
          <% 
            const borderColor = (a.priority === 'High') ? 'red' 
                              : (a.priority === 'Medium') ? 'orange' 
                              : 'gray';
          %>
          <div class="dash-card announcement-card" style="border-left:4px solid <%= borderColor %>; padding:16px; border-radius:8px; background:#fff;">
            
            <!-- Header -->
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
              <div>
                <strong style="font-size:1rem;"><%= a.title %></strong>
                <div style="font-size:0.75rem; color:#666; margin-top:2px;">
                  📅 <%= a.date %> | 👥 <%= a.audience %>
                </div>
              </div>
              <span style="padding:2px 6px; font-size:0.7rem; border-radius:4px; background:<%= borderColor %>; color:white;">
                <%= a.priority %>
              </span>
            </div>

            <!-- Body -->
            <p style="color:#444; margin-bottom:8px; line-height:1.5;"><%= a.body %></p>

            <!-- Image -->
            <% if (a.image) { %>
              <div class="announcement-image" style="margin-top:8px;">
                <img src="/uploads/<%= a.image %>" alt="<%= a.title %>" style="max-width:100%; border-radius:6px;">
              </div>
            <% } %>

          </div>
        <% }) %>
      <% } else { %>
        <p style="color:#666;">No announcements yet.</p>
      <% } %>
    </div>

    <!-- Post Announcement Form -->
    <div class="form-card mt-6" id="postAnnouncement" style="margin-top:32px; padding:16px; border-radius:8px; background:#fff;">
      <div class="form-title" style="font-weight:bold; margin-bottom:16px;">📣 Post New Announcement</div>
      <form method="POST" action="/announcement/add" enctype="multipart/form-data">
        <div class="form-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
          
          <div class="form-group full" style="grid-column:1 / -1;">
            <label>Announcement Title</label>
            <input type="text" name="title" required style="width:100%; padding:8px; border-radius:4px; border:1px solid #ccc;">
          </div>

          <div class="form-group full" style="grid-column:1 / -1;">
            <label>Message / Body</label>
            <textarea name="body" rows="4" required style="width:100%; padding:8px; border-radius:4px; border:1px solid #ccc;"></textarea>
          </div>

          <div class="form-group full" style="grid-column:1 / -1;">
            <label>Upload Image</label>
            <input type="file" name="image" accept="image/*">
          </div>

          <div class="form-group">
            <label>Target Audience</label>
            <select name="audience" style="width:100%; padding:8px; border-radius:4px; border:1px solid #ccc;">
              <option>All Users</option>
              <option>Admin, Staff</option>
              <option>Suppliers</option>
              <option>Institutional Clients</option>
            </select>
          </div>

          <div class="form-group">
            <label>Priority Level</label>
            <select name="priority" style="width:100%; padding:8px; border-radius:4px; border:1px solid #ccc;">
              <option>Low</option>
              <option>Medium</option>
              <option>High</option>
            </select>
          </div>

        </div>

        <div class="form-actions" style="margin-top:16px; display:flex; gap:8px;">
          <button type="submit" class="btn btn-primary">Post Announcement</button>
          <a href="/announcement" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>