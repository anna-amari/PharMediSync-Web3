<% include ../partials/head %>

<!-- Client Portal has its own sidebar -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <h1>💊 PharMediSync</h1>
    <p>Client Portal</p>
  </div>
  <div class="sidebar-role">Institutional Client</div>
  <nav class="sidebar-nav">
    <a href="/client/portal" class="active"><span class="nav-icon">🏠</span> Home Dashboard</a>
    <a href="#catalog">      <span class="nav-icon">📦</span> Product Catalog</a>
    <a href="#orders">       <span class="nav-icon">📋</span> Purchase Order Management</a>
    <a href="#delivery">     <span class="nav-icon">🚚</span> Delivery Schedule</a>
    <a href="#tracking">     <span class="nav-icon">📍</span> Order Tracking</a>
    <a href="#history">      <span class="nav-icon">🕐</span> Transaction History</a>
    <a href="#invoices">     <span class="nav-icon">🧾</span> Invoice and Payment Records</a>
    <a href="#profile">      <span class="nav-icon">👤</span> Profile Management</a>
    <a href="#notif">        <span class="nav-icon">🔔</span> Notifications and Announcements</a>
    <a href="/">             <span class="nav-icon">🚪</span> Log Out</a>
  </nav>
</aside>

<div class="main-area">
  <header class="top-header">
    <span class="page-title">Client Portal — <%= client.name %></span>
    <div class="header-actions">
      <span class="header-badge">📋 <%= client.type %></span>
      <div class="avatar" title="<%= client.contact %>"><%= client.contact.charAt(0) %></div>
    </div>
  </header>
  <div class="content">

    <div class="alert alert-success">👋 Welcome back, <strong><%= client.contact %></strong>! You are logged in as <strong><%= client.name %></strong>.</div>

    <!-- KPIs -->
    <div class="kpi-row" style="grid-template-columns:repeat(4,1fr)">
      <div class="kpi-card white"><div class="kpi-value"><%= orders.length %></div><div class="kpi-label">Total Orders</div></div>
      <div class="kpi-card white"><div class="kpi-value"><%= orders.filter(o=>o.status==='In Transit').length %></div><div class="kpi-label">In Transit</div></div>
      <div class="kpi-card white"><div class="kpi-value">₱<%= client.balance.toLocaleString() %></div><div class="kpi-label">Outstanding</div></div>
      <div class="kpi-card white"><div class="kpi-value">₱<%= client.creditLimit.toLocaleString() %></div><div class="kpi-label">Credit Limit</div></div>
    </div>

    <!-- Recent Orders -->
    <div class="table-card mt-6" id="orders">
      <div class="table-header"><h2>My Recent Orders</h2><a href="#newpo" class="btn btn-primary btn-sm">＋ Place Order</a></div>
      <table>
        <thead><tr><th>Order No.</th><th>Date</th><th>Items</th><th>Amount</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% orders.forEach(o => { %>
          <tr>
            <td><strong><%= o.id %></strong></td>
            <td><%= o.date %></td>
            <td><%= o.items %> items</td>
            <td>₱<%= o.total.toLocaleString() %></td>
            <td>
              <% if(o.status==='Delivered') { %><span class="badge badge-success">Delivered</span>
              <% } else { %><span class="badge badge-info">In Transit</span><% } %>
            </td>
            <td><button class="btn btn-outline btn-sm">Track</button></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Invoices -->
    <div class="table-card mt-6" id="invoices">
      <div class="table-header"><h2>Invoice & Payment Records</h2></div>
      <table>
        <thead><tr><th>Invoice No.</th><th>Order Ref.</th><th>Amount</th><th>Due Date</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% invoices.forEach(inv => { %>
          <tr>
            <td><strong><%= inv.id %></strong></td>
            <td><%= inv.orderId %></td>
            <td>₱<%= inv.amount.toLocaleString() %></td>
            <td><%= inv.due %></td>
            <td>
              <% if(inv.paid) { %><span class="badge badge-success">Paid</span>
              <% } else { %><span class="badge badge-warning">Unpaid</span><% } %>
            </td>
            <td><button class="btn btn-outline btn-sm">Download</button></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Place Order Form -->
    <div class="form-card mt-6" id="newpo">
      <div class="form-title">📋 Place New Purchase Order</div>
      <form method="POST" action="/sales/add">
        <input type="hidden" name="client" value="<%= client.name %>"/>
        <div class="form-grid">
          <div class="form-group full">
            <label>Product(s) Needed</label>
            <textarea name="products" placeholder="List the products and quantities you need…"></textarea>
          </div>
          <div class="form-group"><label>Requested Delivery Date</label><input type="date" name="deliveryDate"/></div>
          <div class="form-group"><label>Estimated Total (₱)</label><input type="number" name="total" min="0" step="0.01"/></div>
          <div class="form-group full"><label>Special Instructions</label><input type="text" name="notes" placeholder="e.g. Deliver to Barangay Hall Annex"/></div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Submit Purchase Order</button>
          <a href="/client/portal" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>

  </div>
</div>
<% include ../partials/footer %>


module.exports = router;