<%- include('../partials/head') %>
<%- include('../partials/sidebar') %>
<div class="main-area">
<%- include('../partials/header') %>
<div class="content">

  <div class="page-header">
    <div><h1>Supplier Management</h1><p>Manage suppliers and purchase orders.</p></div>
    <a href="#addSupplier" class="btn btn-primary">＋ Add Supplier</a>
  </div>

  <!-- Suppliers Table -->
  <div class="table-card">
    <div class="table-header"><h2>Registered Suppliers</h2></div>
    <table>
      <thead>
        <tr><th>ID</th><th>Supplier Name</th><th>Contact</th><th>Phone</th><th>Address</th><th>Rating</th><th>Status</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% suppliers.forEach(s => { %>
        <tr>
          <td><span style="font-size:0.72rem;color:var(--gray-400)"><%= s.id %></span></td>
          <td><strong><%= s.name %></strong><br/><span style="font-size:0.72rem;color:var(--gray-400)"><%= s.email %></span></td>
          <td><%= s.contact %></td>
          <td><%= s.phone %></td>
          <td><%= s.address %></td>
          <td><span style="color:var(--red);font-weight:700">★ <%= s.rating %></span></td>
          <td>
            <% if(s.status==='Active') { %><span class="badge badge-success">Active</span>
            <% } else { %><span class="badge badge-gray">Inactive</span><% } %>
          </td>
          <td><button class="btn btn-outline btn-sm">View POs</button></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Purchase Orders -->
  <div class="table-card mt-6">
    <div class="table-header"><h2>Purchase Orders</h2><a href="#" class="btn btn-primary btn-sm">＋ New PO</a></div>
    <table>
      <thead>
        <tr><th>PO No.</th><th>Supplier</th><th>Date</th><th>Items</th><th>Total Amount</th><th>Status</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% purchaseOrders.forEach(po => { %>
        <tr>
          <td><strong><%= po.id %></strong></td>
          <td><%= po.supplier %></td>
          <td><%= po.date %></td>
          <td><%= po.items %> items</td>
          <td>₱<%= po.total.toLocaleString() %></td>
          <td>
            <% if(po.status==='Approved') { %><span class="badge badge-info">Approved</span>
            <% } else if(po.status==='Delivered') { %><span class="badge badge-success">Delivered</span>
            <% } else if(po.status==='Pending') { %><span class="badge badge-warning">Pending</span>
            <% } else { %><span class="badge badge-danger">Cancelled</span><% } %>
          </td>
          <td><button class="btn btn-outline btn-sm">Details</button></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Add Supplier Form -->
  <div class="form-card mt-6" id="addSupplier">
    <div class="form-title">➕ Register New Supplier</div>
    <form method="POST" action="/supplier/add">
      <div class="form-grid">
        <div class="form-group full"><label>Supplier / Company Name</label><input type="text" name="name" required/></div>
        <div class="form-group"><label>Contact Person</label><input type="text" name="contact" required/></div>
        <div class="form-group"><label>Phone Number</label><input type="text" name="phone" required/></div>
        <div class="form-group"><label>Email Address</label><input type="email" name="email" required/></div>
        <div class="form-group"><label>Address / Location</label><input type="text" name="address" required/></div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Register Supplier</button>
        <a href="/supplier" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>

</div>
<%- include('../partials/footer') %>
