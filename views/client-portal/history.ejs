<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %> | PharMediSync</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/portal.css"/>
</head>
<body>
<div class="app-shell">
  <% include ./sidebar %>
  <div class="main-area">
    <header class="top-header">
      <span class="page-title"><%= title %></span>
      <div class="header-actions">
        <a href="/client-portal/notifications" class="header-badge">🔔 <%= unread %> New</a>
        <div class="avatar"><%= client.contact.charAt(0) %></div>
      </div>
    </header>
    <div class="content">

      <div class="page-header">
        <div><h1>Transaction History</h1><p>Complete record of all your past orders.</p></div>
        <button class="btn btn-outline" onclick="window.print()">⬇ Export PDF</button>
      </div>

      <div class="kpi-row" style="grid-template-columns:repeat(3,1fr)">
        <div class="kpi-card white"><div class="kpi-value"><%= orders.length %></div><div class="kpi-label">Total Transactions</div></div>
        <div class="kpi-card white"><div class="kpi-value">₱<%= orders.reduce((s,o)=>s+o.total,0).toLocaleString() %></div><div class="kpi-label">Total Value</div></div>
        <div class="kpi-card white"><div class="kpi-value"><%= orders.filter(o=>o.status==='Completed').length %></div><div class="kpi-label">Completed</div></div>
      </div>

      <div class="table-card mt-6">
        <div class="table-header"><h2>All Transactions</h2></div>
        <table>
          <thead><tr><th>Order No.</th><th>Date</th><th>Items</th><th>Total Amount</th><th>Payment Status</th><th>Delivery Status</th><th>Order Status</th></tr></thead>
          <tbody>
            <% orders.forEach(o => { %>
            <tr>
              <td><strong><%= o.id %></strong></td>
              <td><%= o.date %></td>
              <td><%= o.items %> items</td>
              <td><strong>₱<%= o.total.toLocaleString() %></strong></td>
              <td>
                <% if(o.payment==='Paid') { %><span class="badge badge-success">Paid</span>
                <% } else if(o.payment==='Invoiced') { %><span class="badge badge-info">Invoiced</span>
                <% } else { %><span class="badge badge-warning">Unpaid</span><% } %>
              </td>
              <td>
                <% if(o.delivery==='Delivered') { %><span class="badge badge-success">Delivered</span>
                <% } else if(o.delivery==='In Transit') { %><span class="badge badge-info">In Transit</span>
                <% } else { %><span class="badge badge-gray">Pending</span><% } %>
              </td>
              <td>
                <% if(o.status==='Completed') { %><span class="badge badge-success">Completed</span>
                <% } else { %><span class="badge badge-warning">Active</span><% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>