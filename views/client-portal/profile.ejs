<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title><%= title %> | PharMediSync</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <link rel="stylesheet" href="/css/portal.css"/>
</head>
<body>
<div class="app-shell">
  <% include ./sidebar %>
  <div class="main-area">
    <header class="top-header">
      <span class="page-title"><%= title %></span>
      <div class="header-actions">
        <a href="/client-portal/notifications" class="header-badge">🔔 <%= unread %> New</a>
        <div class="avatar"><%= client.contact.charAt(0) %></div>
      </div>
    </header>
    <div class="content">

      <div class="page-header">
        <div><h1>Profile Management</h1><p>Manage your account information.</p></div>
      </div>

      <!-- Profile Card -->
      <div style="display:grid;grid-template-columns:280px 1fr;gap:20px">
        <div class="dash-card" style="text-align:center">
          <div style="width:80px;height:80px;background:var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:2rem;color:white;font-weight:900">
            <%= client.contact.charAt(0) %>
          </div>
          <div style="font-family:'Nunito',sans-serif;font-weight:800;font-size:1rem"><%= client.contact %></div>
          <div style="font-size:0.78rem;color:var(--gray-400);margin-top:4px"><%= client.name %></div>
          <span class="badge badge-info" style="margin-top:8px"><%= client.type %></span>
          <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--gray-200)">
            <div style="font-size:0.72rem;color:var(--gray-400)">Credit Limit</div>
            <div style="font-weight:800;color:var(--red);font-size:1.1rem">₱<%= client.creditLimit.toLocaleString() %></div>
          </div>
          <div style="margin-top:8px">
            <div style="font-size:0.72rem;color:var(--gray-400)">Outstanding</div>
            <div style="font-weight:800;font-size:1rem">₱<%= client.balance.toLocaleString() %></div>
          </div>
        </div>

        <div class="form-card" style="max-width:100%">
          <div class="form-title">✏️ Update Profile Information</div>
          <form>
            <div class="form-grid">
              <div class="form-group full"><label>Organization Name</label><input type="text" value="<%= client.name %>"/></div>
              <div class="form-group"><label>Contact Person</label><input type="text" value="<%= client.contact %>"/></div>
              <div class="form-group"><label>Phone Number</label><input type="text" value="<%= client.phone %>"/></div>
              <div class="form-group full"><label>Email Address</label><input type="email" value="<%= client.email %>"/></div>
              <div class="form-group full"><label>Delivery Address</label><input type="text" value="Iriga City Hall, Iriga City, Camarines Sur"/></div>
            </div>
            <div class="form-actions">
              <button type="button" class="btn btn-primary" onclick="alert('Profile updated successfully!')">Save Changes</button>
            </div>
          </form>

          <div class="form-title" style="margin-top:24px">🔒 Change Password</div>
          <form>
            <div class="form-grid">
              <div class="form-group"><label>Current Password</label><input type="password" placeholder="••••••••"/></div>
              <div class="form-group"><label>New Password</label><input type="password" placeholder="••••••••"/></div>
              <div class="form-group full"><label>Confirm New Password</label><input type="password" placeholder="••••••••"/></div>
            </div>
            <div class="form-actions">
              <button type="button" class="btn btn-primary" onclick="alert('Password changed successfully!')">Update Password</button>
            </div>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>