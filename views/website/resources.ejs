<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Resources | Robin Rose Trading</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/website.css"/>
</head>
<body class="w-body">
<%- include('./_nav',{page:'resources'}) %>
<div class="w-page-hero"><div class="w-container">
  <div class="w-breadcrumb"><a href="/website">Home</a> / Resources</div>
  <h1>Resources & Downloads</h1>
  <p>Product catalogs, safety guides, and documentation for healthcare providers.</p>
</div></div>
<section class="w-section"><div class="w-container">
  <div class="w-label">Downloads</div>
  <h2 class="w-title">Helpful Documents & Guides</h2>
  <div class="w-res-grid">
    <% [
      {icon:'📄',title:'Complete Product Catalog 2025',        desc:'Full list of 500+ products with SKUs, specs, and pricing. Updated March 2025.',           tag:'PDF · 4.2 MB'},
      {icon:'🩺',title:'Diagnostics Equipment Guide',          desc:'User guides for BP monitors, glucose meters, pulse oximeters, and thermometers.',          tag:'PDF · 1.8 MB'},
      {icon:'🧤',title:'PPE Selection & Usage Guide',          desc:'Proper selection, use, and disposal of PPE. Based on DOH guidelines.',                    tag:'PDF · 1.1 MB'},
      {icon:'💉',title:'Surgical Consumables Reference',       desc:'Specifications for syringes, catheters, IV sets, and surgical disposables.',               tag:'PDF · 2.3 MB'},
      {icon:'⚠️',title:'Safety Data Sheets (MSDS)',            desc:'Material safety data sheets for disinfectants, alcohol, and chemical supplies.',           tag:'PDF · 3.0 MB'},
      {icon:'🏛️',title:'Government Procurement Guide',         desc:'How LGUs and agencies can procure through PhilGEPS and direct contracting.',              tag:'PDF · 0.9 MB'},
      {icon:'🔬',title:'Product Authenticity Verification',    desc:'How to verify FDA registration numbers and identify genuine medical products.',             tag:'PDF · 0.6 MB'},
      {icon:'📋',title:'Sample Purchase Order Template',       desc:'Downloadable PO template pre-filled for Robin Rose Trading institutional orders.',          tag:'DOCX · 0.2 MB'},
      {icon:'🧾',title:'BIR Official Receipt Guide',           desc:'Understanding your BIR-compliant receipts and VAT computation for accounting.',            tag:'PDF · 0.4 MB'},
    ].forEach(r=>{ %>
    <div class="w-res">
      <div class="w-res-ic"><%= r.icon %></div>
      <div class="w-res-bd">
        <h4><%= r.title %></h4>
        <p><%= r.desc %></p>
        <span style="font-size:0.68rem;color:var(--w-gray-400)"><%= r.tag %></span><br/>
        <a href="#" onclick="alert('Download: <%= r.title %>');return false">⬇ Download →</a>
      </div>
    </div>
    <% }) %>
  </div>
</div></section>
<%- include('./_footer') %>
</body></html>